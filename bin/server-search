#!/usr/bin/env bash
set -euo pipefail

# server-search — search for burnable images by name
# Usage: server-search <query>
#
# Searches the local library (LIBRARY_PATH) first; if nothing matches there,
# falls back to the media server (MEDIA_HOST:MEDIA_PATH). Case-insensitive;
# spaces in the query become wildcards (fuzzy match).
#
# Output is tab-delimited: <source>\t<size>\t<path>
#   source  "local" | "server"
#   path    relative to LIBRARY_PATH (local) or MEDIA_PATH (server)
#
# Environment overrides:
#   LIBRARY_PATH  Local search root  (default: $HOME/roms)
#   MEDIA_HOST    SSH target         (default: reset@192.168.1.28)
#   MEDIA_PATH    Server search root (default: /var/lib/transmission-daemon/downloads)

LIBRARY_PATH="${LIBRARY_PATH:-$HOME/roms}"
MEDIA_HOST="${MEDIA_HOST:-reset@192.168.1.28}"
MEDIA_PATH="${MEDIA_PATH:-/var/lib/transmission-daemon/downloads}"

usage() {
    echo "Usage: server-search <query>" >&2
    echo "" >&2
    echo "Case-insensitive. Spaces become wildcards: \"sonic cd\" matches" >&2
    echo "\"Sonic CD (USA).7z\", \"Sonic the Hedgehog CD\", etc." >&2
    echo "" >&2
    echo "Searches LIBRARY_PATH first, then the media server if nothing local." >&2
    echo "" >&2
    echo "Environment:" >&2
    echo "  LIBRARY_PATH  Local search root (default: $LIBRARY_PATH)" >&2
    echo "  MEDIA_HOST    SSH target (default: $MEDIA_HOST)" >&2
    echo "  MEDIA_PATH    Server search root (default: $MEDIA_PATH)" >&2
    exit 1
}

[[ $# -eq 0 ]] && usage

# Join args and replace spaces with * for fuzzy matching
query="$*"
pattern="*${query// /*}*"

# --- local library first ---
found_local=0
if [[ -d "$LIBRARY_PATH" ]]; then
    while IFS= read -r f; do
        found_local=1
        if [[ -f "$f" ]]; then
            size="$(du -sh "$f" 2>/dev/null | cut -f1)"
        else
            size="[dir]"
        fi
        printf 'local\t%s\t%s\n' "$size" "${f#"$LIBRARY_PATH"/}"
    done < <(find "$LIBRARY_PATH" -iname "$pattern" \
        -not -name '*.part' \
        -not -name '*.tmp' \
        2>/dev/null | sort)
fi

# If the local library had any hits, don't touch the server.
[[ "$found_local" -eq 1 ]] && exit 0

# --- fall back to the media server ---
ssh "$MEDIA_HOST" "
find '$MEDIA_PATH' -iname '$pattern' \
    -not -name '*.part' \
    -not -name '*.tmp' \
    2>/dev/null \
| sort \
| while IFS= read -r f; do
    if [ -f \"\$f\" ]; then
        size=\$(du -sh \"\$f\" 2>/dev/null | cut -f1)
        printf 'server\t%s\t%s\n' \"\$size\" \"\${f#${MEDIA_PATH}/}\"
    else
        printf 'server\t%s\t%s\n' '[dir]' \"\${f#${MEDIA_PATH}/}\"
    fi
done
"
