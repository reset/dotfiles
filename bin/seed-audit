#!/usr/bin/env python3
"""
seed-audit — review seeding torrents and remove ones that have cleared IPTorrents HnR

IPTorrents Hit and Run rule: you must seed each torrent to BOTH a 1.0 ratio AND
for at least 48 hours. Failing to meet both gets you an HnR strike; three strikes
restricts your account. This tool marks a torrent safe only when both conditions
are satisfied.

Usage: seed-audit [--host HOST] [--port PORT] [--user USER] [--pass PASS]
                  [--min-ratio N] [--min-hours N] [--delete-data]

Defaults use conservative thresholds (1.0 ratio, 72h) giving a buffer above the
strict IPT minimums (1.0 ratio, 48h).

Environment:
  TRANSMISSION_HOST   default: 192.168.1.28
  TRANSMISSION_PORT   default: 9091
  TRANSMISSION_USER   default: transmission
  TRANSMISSION_PASS   default: media-server
"""

import argparse
import json
import os
import sys
import urllib.request
import urllib.error
from datetime import timedelta

#
# Config defaults
#

DEFAULT_HOST  = os.environ.get("TRANSMISSION_HOST", "192.168.1.28")
DEFAULT_PORT  = int(os.environ.get("TRANSMISSION_PORT", "9091"))
DEFAULT_USER  = os.environ.get("TRANSMISSION_USER", "transmission")
DEFAULT_PASS  = os.environ.get("TRANSMISSION_PASS", "media-server")
DEFAULT_RATIO = 1.0
DEFAULT_HOURS = 72

#
# Transmission RPC
#

class TransmissionError(Exception):
    pass

class Transmission:
    def __init__(self, host, port, user, password):
        self.url      = f"http://{host}:{port}/transmission/rpc"
        self.user     = user
        self.password = password
        self.session_id = self._get_session_id()

    def _get_session_id(self):
        # Transmission returns 409 with the session ID on first request
        mgr = urllib.request.HTTPPasswordMgrWithDefaultRealm()
        mgr.add_password(None, self.url, self.user, self.password)
        opener = urllib.request.build_opener(urllib.request.HTTPBasicAuthHandler(mgr))
        try:
            opener.open(self.url)
        except urllib.error.HTTPError as e:
            if e.code == 409:
                return e.headers.get("X-Transmission-Session-Id", "")
            elif e.code == 401:
                raise TransmissionError("Authentication failed — check username and password.")
            raise TransmissionError(f"Unexpected HTTP {e.code} from Transmission.")
        except urllib.error.URLError as e:
            raise TransmissionError(f"Could not connect to Transmission: {e.reason}")
        return ""

    def _request(self, method, arguments=None):
        payload = json.dumps({"method": method, "arguments": arguments or {}}).encode()
        mgr = urllib.request.HTTPPasswordMgrWithDefaultRealm()
        mgr.add_password(None, self.url, self.user, self.password)
        opener = urllib.request.build_opener(urllib.request.HTTPBasicAuthHandler(mgr))
        req = urllib.request.Request(
            self.url, data=payload,
            headers={"X-Transmission-Session-Id": self.session_id,
                     "Content-Type": "application/json"},
        )
        try:
            with opener.open(req) as resp:
                return json.loads(resp.read())
        except urllib.error.HTTPError as e:
            if e.code == 409:
                self.session_id = e.headers.get("X-Transmission-Session-Id", "")
                return self._request(method, arguments)
            raise TransmissionError(f"HTTP {e.code} from Transmission.")

    def get_torrents(self, fields):
        result = self._request("torrent-get", {"fields": fields})
        return result["arguments"]["torrents"]

    def remove(self, ids, delete_data=False):
        self._request("torrent-remove", {"ids": ids, "delete-local-data": delete_data})

#
# Formatting helpers
#

def fmt_size(n_bytes):
    for unit in ("B", "KB", "MB", "GB", "TB"):
        if n_bytes < 1024:
            return f"{n_bytes:.1f} {unit}"
        n_bytes /= 1024
    return f"{n_bytes:.1f} PB"

def fmt_duration(seconds):
    if seconds < 0:
        return "unknown"
    d = timedelta(seconds=int(seconds))
    days    = d.days
    hours   = d.seconds // 3600
    minutes = (d.seconds % 3600) // 60
    if days > 0:
        return f"{days}d {hours:02d}h"
    if hours > 0:
        return f"{hours}h {minutes:02d}m"
    return f"{minutes}m"

def fmt_ratio(r):
    if r < 0:
        return "  n/a"
    return f"{r:5.2f}"

#
# Main
#

FIELDS = [
    "id", "name", "totalSize", "uploadRatio", "secondsSeeding",
    "status", "percentDone", "downloadDir", "error", "errorString",
]

# Transmission status codes
STATUS_STOPPED       = 0
STATUS_SEED_QUEUED   = 5
STATUS_SEEDING       = 6

CYAN   = "\033[96m"
GREEN  = "\033[92m"
YELLOW = "\033[93m"
RED    = "\033[91m"
BOLD   = "\033[1m"
DIM    = "\033[2m"
RESET  = "\033[0m"

def colored(text, *codes):
    if not sys.stdout.isatty():
        return text
    return "".join(codes) + text + RESET

def main():
    parser = argparse.ArgumentParser(
        description="Review seeding torrents and remove ones that have met HnR obligations.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument("--host",        default=DEFAULT_HOST)
    parser.add_argument("--port",        type=int, default=DEFAULT_PORT)
    parser.add_argument("--user",        default=DEFAULT_USER)
    parser.add_argument("--pass",        dest="password", default=DEFAULT_PASS)
    parser.add_argument("--min-ratio",   type=float, default=DEFAULT_RATIO,
                        help=f"Minimum ratio to consider obligation met (default: {DEFAULT_RATIO})")
    parser.add_argument("--min-hours",   type=int, default=DEFAULT_HOURS,
                        help=f"Minimum seed time in hours (default: {DEFAULT_HOURS})")
    parser.add_argument("--delete-data", action="store_true",
                        help="Also delete downloaded files when removing a torrent")
    parser.add_argument("--yes",         action="store_true",
                        help="Remove all eligible torrents without prompting")
    args = parser.parse_args()

    min_seconds = args.min_hours * 3600

    print(f"Connecting to Transmission at {args.host}:{args.port}...")
    try:
        tx = Transmission(args.host, args.port, args.user, args.password)
    except TransmissionError as e:
        print(colored(f"Error: {e}", RED), file=sys.stderr)
        sys.exit(1)

    all_torrents = tx.get_torrents(FIELDS)

    # Only care about completed downloads
    completed = [t for t in all_torrents if t["percentDone"] >= 1.0]

    if not completed:
        print("No completed torrents found.")
        return

    def is_safe(t):
        # IPTorrents HnR rule: must meet BOTH ratio AND seed time to avoid a strike
        return t["uploadRatio"] >= args.min_ratio and t["secondsSeeding"] >= min_seconds

    def is_stopped(t):
        return t["status"] == STATUS_STOPPED

    safe            = [t for t in completed if is_safe(t)]
    stopped_safe    = [t for t in safe if is_stopped(t)]       # cleared HnR, not currently seeding
    seeding_active  = [t for t in completed if not is_safe(t) and not is_stopped(t)]
    stopped_at_risk = [t for t in completed if not is_safe(t) and is_stopped(t)]

    # Sort all groups by ratio descending
    safe.sort(key=lambda t: t["uploadRatio"], reverse=True)
    seeding_active.sort(key=lambda t: t["uploadRatio"], reverse=True)
    stopped_at_risk.sort(key=lambda t: t["uploadRatio"], reverse=True)

    # ── SAFE TO REMOVE ──────────────────────────────────────────────────────────
    if safe:
        print()
        print(colored(f"SAFE TO REMOVE  ({len(safe)} torrents — ratio ≥ {args.min_ratio} AND seeded ≥ {args.min_hours}h — IPT HnR cleared)", BOLD + GREEN))
        if stopped_safe:
            print(colored(f"  ({len(stopped_safe)} of these are stopped and no longer seeding)", DIM))
        print(colored("─" * 80, GREEN))
        for i, t in enumerate(safe, 1):
            idx    = colored(f"{i:>3}", BOLD)
            ratio  = colored(fmt_ratio(t["uploadRatio"]), GREEN)
            dur    = colored(fmt_duration(t["secondsSeeding"]), CYAN)
            size   = colored(fmt_size(t["totalSize"]), DIM)
            paused = colored(" [stopped]", DIM) if is_stopped(t) else ""
            print(f"  {idx}  [{ratio}] [{dur:>9}]  {t['name']} ({size}){paused}")
    else:
        print()
        print(colored("No torrents have met the HnR threshold yet.", YELLOW))

    # ── STOPPED — HnR NOT MET ───────────────────────────────────────────────────
    if stopped_at_risk:
        print()
        print(colored(f"⚠  STOPPED — HnR NOT MET  ({len(stopped_at_risk)} torrents)", BOLD + RED))
        print(colored("   These are not seeding and haven't cleared IPT's HnR rule.", RED))
        print(colored("   Restart them in Transmission or you risk HnR strikes.", RED))
        print(colored("─" * 80, RED))
        for t in stopped_at_risk:
            ratio  = colored(fmt_ratio(t["uploadRatio"]), RED)
            dur    = colored(fmt_duration(t["secondsSeeding"]), CYAN)
            size   = colored(fmt_size(t["totalSize"]), DIM)
            needs  = []
            if t["uploadRatio"] < args.min_ratio:
                needs.append(f"ratio {t['uploadRatio']:.2f}→{args.min_ratio}")
            if t["secondsSeeding"] < min_seconds:
                needs.append(f"{fmt_duration(max(0, min_seconds - t['secondsSeeding']))} more seeding")
            needs_str = colored(f"  needs: {', '.join(needs)}", DIM) if needs else ""
            print(f"    [{ratio}] [{dur:>9}]  {t['name']} ({size}){needs_str}")

    # ── STILL SEEDING ────────────────────────────────────────────────────────────
    if seeding_active:
        print()
        print(colored(f"STILL SEEDING  ({len(seeding_active)} torrents — leave these alone)", BOLD + YELLOW))
        print(colored("─" * 80, YELLOW))
        for t in seeding_active:
            ratio     = colored(fmt_ratio(t["uploadRatio"]), YELLOW)
            dur       = colored(fmt_duration(t["secondsSeeding"]), CYAN)
            size      = colored(fmt_size(t["totalSize"]), DIM)
            needs     = []
            if t["uploadRatio"] < args.min_ratio:
                needs.append(f"ratio {t['uploadRatio']:.2f}→{args.min_ratio}")
            if t["secondsSeeding"] < min_seconds:
                needs.append(f"{fmt_duration(max(0, min_seconds - t['secondsSeeding']))} more seeding")
            needs_str = colored(f"  needs: {', '.join(needs)}", DIM) if needs else ""
            print(f"    [{ratio}] [{dur:>9}]  {t['name']} ({size}){needs_str}")

    if not safe:
        return

    print()

    if args.yes:
        to_remove = safe
    else:
        prompt = f"Remove which? (1-{len(safe)}, ranges like 1-3, \"all\", or q to quit): "
        try:
            raw = input(prompt).strip().lower()
        except (EOFError, KeyboardInterrupt):
            print("\nCancelled.")
            return

        if raw in ("q", "quit", ""):
            print("Cancelled.")
            return

        if raw == "all":
            to_remove = safe
        else:
            indices = set()
            for part in raw.split(","):
                part = part.strip()
                if "-" in part:
                    lo, _, hi = part.partition("-")
                    try:
                        for n in range(int(lo), int(hi) + 1):
                            indices.add(n)
                    except ValueError:
                        print(colored(f"Invalid range: {part}", RED), file=sys.stderr)
                        sys.exit(1)
                else:
                    try:
                        indices.add(int(part))
                    except ValueError:
                        print(colored(f"Invalid selection: {part}", RED), file=sys.stderr)
                        sys.exit(1)

            invalid = [n for n in indices if n < 1 or n > len(safe)]
            if invalid:
                print(colored(f"Out of range: {', '.join(str(n) for n in invalid)}", RED), file=sys.stderr)
                sys.exit(1)

            to_remove = [safe[n - 1] for n in sorted(indices)]

    if not to_remove:
        print("Nothing selected.")
        return

    # Confirm delete-data if not already passed as flag
    delete_data = args.delete_data
    if not delete_data and not args.yes:
        print()
        total_size = sum(t["totalSize"] for t in to_remove)
        print(f"Selected {len(to_remove)} torrent(s) — {fmt_size(total_size)} on disk.")
        try:
            answer = input("Delete downloaded files too? [y/N]: ").strip().lower()
        except (EOFError, KeyboardInterrupt):
            print("\nCancelled.")
            return
        delete_data = answer in ("y", "yes")

    print()
    ids = [t["id"] for t in to_remove]
    try:
        tx.remove(ids, delete_data=delete_data)
    except TransmissionError as e:
        print(colored(f"Error removing torrents: {e}", RED), file=sys.stderr)
        sys.exit(1)

    action = "Removed torrents and deleted files" if delete_data else "Removed torrents (files kept)"
    print(colored(f"✓ {action}:", GREEN))
    for t in to_remove:
        print(f"  • {t['name']}")

if __name__ == "__main__":
    main()
