#!/usr/bin/env bash
set -euo pipefail

icon=$'\xef\x82\xa0'  # U+F0A0 nf-fa-hdd
vm_stat | awk -v icon="$icon" '
/Pages free:/              { free  = $3 }
/Pages active:/            { active = $3 }
/Pages inactive:/          { inactive = $3 }
/Pages wired down:/        { wired = $4 }
/Pages occupied by compressor:/ { comp = $5 }
END {
  used  = active + wired + comp
  total = free + active + inactive + wired + comp
  printf "%s %.0f%%\n", icon, (used / total) * 100
}'
