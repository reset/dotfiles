#!/usr/bin/env bash
# Upgrade the system Nix installation to the latest stable release.
#
# Must use the profile-linked nix binary, not the one resolved from the
# current shell PATH — the dev shell (via direnv/nix-direnv) puts a
# store-path nix directly in PATH, and nix upgrade-nix rejects binaries
# that aren't installed through a profile.
#
# Requires sudo because Nix is installed multi-user on macOS — the daemon
# and store are owned by root.
set -euo pipefail

readonly NIX="/nix/var/nix/profiles/default/bin/nix"

if [[ ! -x "$NIX" ]]; then
  echo >&2 "error: nix not found at $NIX — is Nix installed multi-user?"
  exit 1
fi

sudo "$NIX" upgrade-nix "$@"
