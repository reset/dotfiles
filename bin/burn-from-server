#!/usr/bin/env bash
set -euo pipefail

# burn-from-server — search the library (local first, server fallback), pick a
# file, and burn it. Local hits burn straight from disk; server hits download
# to a temp dir first.
# Usage: burn-from-server <query> [--speed N]
#
# Environment overrides (passed through to server-search and burn-disc):
#   LIBRARY_PATH  Local search root  (default: $HOME/roms)
#   MEDIA_HOST    SSH target         (default: reset@192.168.1.28)
#   MEDIA_PATH    Server search root (default: /var/lib/transmission-daemon/downloads)

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LIBRARY_PATH="${LIBRARY_PATH:-$HOME/roms}"
MEDIA_HOST="${MEDIA_HOST:-reset@192.168.1.28}"
MEDIA_PATH="${MEDIA_PATH:-/var/lib/transmission-daemon/downloads}"

# Format a tab-delimited "<source>\t<size>\t<path>" result line for display.
fmt_result() {
    local src size path
    IFS=$'\t' read -r src size path <<< "$1"
    printf '[%s] %-8s %s' "$src" "$size" "$path"
}

usage() {
    echo "Usage: burn-from-server <query> [--speed N]" >&2
    echo "" >&2
    echo "Searches the media server for files matching query, prompts to" >&2
    echo "select one, downloads it, and burns it to disc." >&2
    exit 1
}

# --- argument parsing ---
speed=""
dry_run=0
query_parts=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        --speed)
            speed="$2"
            shift 2
            ;;
        --dry-run)
            dry_run=1
            shift
            ;;
        -h|--help)
            usage
            ;;
        -*)
            echo >&2 "Unknown option: $1"
            usage
            ;;
        *)
            query_parts+=("$1")
            shift
            ;;
    esac
done

[[ ${#query_parts[@]} -eq 0 ]] && usage
query="${query_parts[*]}"

# --- search ---
echo "Searching for \"$query\"..."
echo ""

results=()
while IFS= read -r line; do
    results+=("$line")
done < <("$SCRIPT_DIR/server-search" "$query" 2>/dev/null)

if [[ ${#results[@]} -eq 0 ]]; then
    echo "No results found for \"$query\"." >&2
    exit 1
fi

# --- pick ---
if [[ ${#results[@]} -eq 1 ]]; then
    fmt_result "${results[0]}"; echo ""
    chosen="${results[0]}"
    if [[ "$dry_run" -eq 0 ]]; then
        echo ""
        read -rp "Burn this? [Y/n] " confirm
        confirm="$(echo "${confirm:-y}" | tr '[:upper:]' '[:lower:]')"
        [[ "$confirm" == "n" ]] && { echo "Cancelled."; exit 0; }
    fi
else
    for i in "${!results[@]}"; do
        printf "  %d) %s\n" "$((i + 1))" "$(fmt_result "${results[$i]}")"
    done
    if [[ "$dry_run" -eq 1 ]]; then
        echo ""
        echo "(dry-run: would prompt for selection)"
        exit 0
    fi
    echo ""
    read -rp "Pick one (1-${#results[@]}) or q to quit: " pick
    pick="$(echo "$pick" | tr '[:upper:]' '[:lower:]')"
    [[ "$pick" == "q" ]] && { echo "Cancelled."; exit 0; }
    if ! [[ "$pick" =~ ^[0-9]+$ ]] || (( pick < 1 || pick > ${#results[@]} )); then
        echo >&2 "Invalid selection."
        exit 1
    fi
    chosen="${results[$((pick - 1))]}"
fi

# Parse the chosen result into its source and path (tab-delimited)
IFS=$'\t' read -r src _size rel_path <<< "$chosen"

echo ""

# --- local source: burn straight from the library, no download ---
if [[ "$src" == "local" ]]; then
    local_file="${LIBRARY_PATH}/${rel_path}"
    if [[ "$dry_run" -eq 1 ]]; then
        echo "Would burn (local): ${local_file}${speed:+ at ${speed}x}"
        exit 0
    fi
    exec "$SCRIPT_DIR/burn-disc" "$local_file" ${speed:+--speed "$speed"}
fi

# --- server source: download to a temp dir, then burn ---
remote_file="${MEDIA_PATH}/${rel_path}"

if [[ "$dry_run" -eq 1 ]]; then
    echo "Would download: ${MEDIA_HOST}:${remote_file}"
    echo "Would burn:     $(basename "$rel_path")${speed:+ at ${speed}x}"
    exit 0
fi

echo "Downloading $(basename "$rel_path")..."

work_dir="$(mktemp -d)"
trap 'rm -rf "$work_dir"' EXIT

local_file="$work_dir/$(basename "$rel_path")"
rsync -a --progress --protect-args "${MEDIA_HOST}:${remote_file}" "$local_file"

echo ""
"$SCRIPT_DIR/burn-disc" "$local_file" ${speed:+--speed "$speed"}
