#!/usr/bin/env bash
set -euo pipefail

# burn-disc — extract and burn a disc image to a physical CD
# Supported inputs: .7z .zip .rar archives, .bin/.cue, .chd, .ccd/.img, .iso
# Usage: burn-disc <file> [--speed N] [--dry-run]

usage() {
    echo "Usage: burn-disc <file> [--speed N] [--dry-run]" >&2
    echo "" >&2
    echo "Supported formats:" >&2
    echo "  Archives:   .7z .zip .rar  (containing a disc image)" >&2
    echo "  Images:     .bin/.cue  .chd  .ccd/.img  .iso" >&2
    echo "" >&2
    echo "Options:" >&2
    echo "  --speed N    Burn speed (default: drive minimum). Lower is more" >&2
    echo "               compatible with aging retro hardware." >&2
    echo "  --dry-run    Extract and convert only; print the generated CUE" >&2
    echo "               and exit without burning." >&2
    exit 1
}

# Returns the drive's minimum supported write speed, or empty string if unknown.
detect_min_speed() {
    local speeds_line
    speeds_line="$(drutil status 2>/dev/null | grep 'Write Speeds:')" || true
    if [[ -n "$speeds_line" ]]; then
        echo "$speeds_line" | grep -o '[0-9]*x' | head -1 | tr -d 'x'
    fi
}

check_dep() {
    local cmd="$1"
    local install_hint="$2"
    if ! command -v "$cmd" >/dev/null 2>&1; then
        echo >&2 "Error: '$cmd' not found. Install with: $install_hint"
        exit 1
    fi
}

# --- argument parsing ---
speed=""
dry_run=0
input_file=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --speed)
            speed="$2"
            shift 2
            ;;
        --dry-run)
            dry_run=1
            shift
            ;;
        -h|--help)
            usage
            ;;
        -*)
            echo >&2 "Unknown option: $1"
            usage
            ;;
        *)
            input_file="$1"
            shift
            ;;
    esac
done

[[ -z "$input_file" ]] && usage
[[ ! -f "$input_file" ]] && { echo >&2 "Error: file not found: $input_file"; exit 1; }

# --- setup ---
work_dir="$(mktemp -d)"
trap 'rm -rf "$work_dir"' EXIT

ext="$(echo "${input_file##*.}" | tr '[:upper:]' '[:lower:]')"

cue_file=""
chd_file=""
ccd_file=""
iso_file=""
needs_swap=0  # set to 1 for CCD/img sources — audio is stored big-endian

# --- extract archives ---
extract_archive() {
    local archive="$1"
    local archive_ext
    archive_ext="$(echo "${archive##*.}" | tr '[:upper:]' '[:lower:]')"

    echo "Extracting $(basename "$archive")..."

    case "$archive_ext" in
        7z)
            check_dep 7z "brew install p7zip"
            7z x "$archive" -o"$work_dir" -y
            ;;
        zip)
            unzip -q "$archive" -d "$work_dir"
            ;;
        rar)
            check_dep unrar "brew install unrar"
            unrar x -y "$archive" "$work_dir/"
            ;;
    esac

    cue_file="$(find "$work_dir" -iname '*.cue' | head -1)"
    chd_file="$(find "$work_dir" -iname '*.chd' | head -1)"
    ccd_file="$(find "$work_dir" -iname '*.ccd' | head -1)"
    iso_file="$(find "$work_dir" -iname '*.iso' | head -1)"

    # bin with no cue is a problem — warn early
    if [[ -z "$cue_file" && -z "$chd_file" && -z "$ccd_file" && -z "$iso_file" ]]; then
        local bin_file
        bin_file="$(find "$work_dir" -iname '*.bin' | head -1)"
        if [[ -n "$bin_file" ]]; then
            echo >&2 "Error: found $(basename "$bin_file") but no matching .cue file in archive."
            echo >&2 "A .cue file is required to burn a multi-track disc correctly."
            exit 1
        fi
        echo >&2 "Error: no burnable image found in archive (looked for .cue, .chd, .iso)."
        exit 1
    fi
}

# --- route by file extension ---
case "$ext" in
    7z|zip|rar)
        extract_archive "$input_file"
        ;;
    cue)
        cue_file="$input_file"
        ;;
    chd)
        chd_file="$input_file"
        ;;
    iso)
        iso_file="$input_file"
        ;;
    ccd)
        ccd_file="$input_file"
        ;;
    bin|img)
        base="${input_file%.*}"
        if [[ -f "${base}.ccd" ]]; then
            ccd_file="${base}.ccd"
        elif [[ -f "${base}.CCD" ]]; then
            ccd_file="${base}.CCD"
        elif [[ -f "${base}.cue" ]]; then
            cue_file="${base}.cue"
        elif [[ -f "${base}.CUE" ]]; then
            cue_file="${base}.CUE"
        else
            echo >&2 "Error: no .cue or .ccd file found alongside $(basename "$input_file")"
            echo >&2 "Expected: ${base}.cue or ${base}.ccd"
            exit 1
        fi
        ;;
    *)
        echo >&2 "Error: unsupported format: .$ext"
        echo >&2 ""
        usage
        ;;
esac

# --- convert CHD → bin/cue if needed ---
if [[ -n "$chd_file" ]]; then
    check_dep chdman "brew install mame"
    echo "Converting CHD → bin/cue..."
    base_name="$(basename "${chd_file%.*}")"
    converted_cue="$work_dir/${base_name}.cue"
    chdman extractcd \
        -i "$chd_file" \
        -o "$converted_cue" \
        -ob "$work_dir/${base_name}.bin"
    cue_file="$converted_cue"
fi

# --- convert CCD → bin/cue if needed ---
if [[ -n "$ccd_file" ]]; then
    check_dep python3 "brew install python"
    echo "Converting CCD → cue..."
    base_name="$(basename "${ccd_file%.*}")"
    ccd_dir="$(dirname "$ccd_file")"

    # find the matching .img (same directory, same base name, case-insensitive)
    img_file="$(find "$ccd_dir" -maxdepth 1 -iname "${base_name}.img" | head -1)"
    if [[ -z "$img_file" ]]; then
        echo >&2 "Error: no .img file found alongside $(basename "$ccd_file")"
        exit 1
    fi

    converted_cue="$work_dir/${base_name}.cue"
    img_basename="$(basename "$img_file")"

    python3 - "$ccd_file" "$img_basename" > "$converted_cue" << 'PYEOF'
import re, sys

def lba_to_msf(lba):
    return f"{lba // 75 // 60:02d}:{(lba // 75) % 60:02d}:{lba % 75:02d}"

ccd_path, img_basename = sys.argv[1], sys.argv[2]

# CCD files use [Entry N] sections with Point= to identify tracks.
# Point 0x01-0x63 = track numbers; 0xa0/a1/a2 = disc TOC metadata.
# Control bit 0x04 = data track; 0x00 = audio.
# PLBA = sector offset in the .img file where the track starts.

entries = {}
current_entry = None
current_data = {}

with open(ccd_path) as f:
    for line in f:
        line = line.strip()
        m = re.match(r'\[Entry (\d+)\]', line, re.IGNORECASE)
        if m:
            if current_entry is not None:
                entries[current_entry] = current_data
            current_entry = int(m.group(1))
            current_data = {}
        elif current_entry is not None and '=' in line:
            k, v = line.split('=', 1)
            current_data[k.strip()] = v.strip()
if current_entry is not None:
    entries[current_entry] = current_data

tracks = {}
for data in entries.values():
    point_str = data.get('Point', '')
    try:
        point = int(point_str, 16)
    except ValueError:
        continue
    if 0x01 <= point <= 0x63:
        control = int(data.get('Control', '0x00'), 16)
        plba = int(data.get('PLBA', '0'))
        tracks[point] = {'is_data': bool(control & 0x04), 'plba': plba}

print(f'FILE "{img_basename}" BINARY')
for num in sorted(tracks):
    t = tracks[num]
    ttype = 'MODE1/2352' if t['is_data'] else 'AUDIO'
    print(f'  TRACK {num:02d} {ttype}')
    # Audio tracks 2+ have a standard 2-second (150-frame) pregap in the image
    if num > 1 and not t['is_data']:
        pregap_lba = t['plba'] - 150
        if pregap_lba >= 0:
            print(f'    INDEX 00 {lba_to_msf(pregap_lba)}')
    print(f'    INDEX 01 {lba_to_msf(t["plba"])}')
PYEOF

    # cdrdao resolves the img path relative to the cue — symlink into work_dir
    # only needed when img wasn't already extracted there
    if [[ "$(dirname "$img_file")" != "$work_dir" ]]; then
        ln -sf "$img_file" "$work_dir/${img_basename}"
    fi
    cue_file="$converted_cue"
    needs_swap=1  # CloneCD .img audio sectors are big-endian
fi

# --- dry run: print CUE and exit ---
if [[ "$dry_run" -eq 1 ]]; then
    if [[ -n "$cue_file" ]]; then
        echo "=== $(basename "$cue_file") ==="
        cat "$cue_file"
    elif [[ -n "$iso_file" ]]; then
        echo "ISO: $(basename "$iso_file") (no CUE — single data track)"
    fi
    exit 0
fi

# --- burn ---
check_dep cdrdao "brew install cdrdao"

# resolve speed — detect drive minimum if not specified by user
if [[ -z "$speed" ]]; then
    speed="$(detect_min_speed)"
    if [[ -n "$speed" ]]; then
        echo "Detected drive minimum write speed: ${speed}x"
    else
        echo "Warning: could not detect drive write speed; cdrdao will use its default." >&2
    fi
else
    min_speed="$(detect_min_speed)"
    if [[ -n "$min_speed" && "$speed" -lt "$min_speed" ]]; then
        echo "Warning: requested speed ${speed}x is below drive minimum ${min_speed}x." >&2
        echo "         cdrdao will use ${min_speed}x instead." >&2
    fi
fi

echo ""
echo "Scanning for optical drives..."
cdrdao scanbus 2>/dev/null || true
echo ""

if [[ -n "$cue_file" ]]; then
    echo "Burning: $(basename "$cue_file")${speed:+ at ${speed}x}"
    echo ""
    # cdrdao resolves FILE paths relative to the invocation directory, not the cue
    cd "$(dirname "$cue_file")"
    cdrdao write \
        ${speed:+--speed "$speed"} \
        $([[ "$needs_swap" -eq 1 ]] && echo "--swap") \
        "$(basename "$cue_file")"
elif [[ -n "$iso_file" ]]; then
    check_dep cdrecord "brew install cdrtools"
    echo "Burning: $(basename "$iso_file")${speed:+ at ${speed}x}"
    echo ""
    cdrecord -v ${speed:+"speed=${speed}"} "$iso_file"
fi

echo ""
echo "Done!"
